# Copy to ~/.config/macflow/connect.env and adjust for your environment.
# quick-connect.sh will auto-load this file.

# Optional extra host candidates (host only, comma separated)
ISTORE_HOST=192.168.50.1,10.0.0.1

# Optional explicit panel URLs (preferred over host scan)
# Supports remote domains (Tailscale / DDNS / tunnel) and local addresses.
ISTORE_PANEL_URLS=https://router.tailnet.ts.net:18080,https://router.example.com

# Optional explicit LuCI URLs
ISTORE_LUCI_URLS=https://router.tailnet.ts.net,http://192.168.50.1

# Optional explicit SSH targets
# Format: user@host:port,host:port,host
ISTORE_SSH_TARGETS=root@router.tailnet.ts.net:22,root@100.64.0.10:22

# Optional discovery behavior
MACFLOW_DISCOVER_TIMEOUT=3
MACFLOW_INSECURE_TLS=0
