#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

_load_cfg() {
    config_load macflow
    config_get enabled main enabled 1
    config_get bind_addr main bind_addr "0.0.0.0"
    config_get listen_port main listen_port "18080"
    config_get app_root main app_root "/opt/macflow"
    config_get data_dir main data_dir "/opt/macflow/data"
    config_get clash_api main clash_api "http://127.0.0.1:9090"
    config_get respawn_threshold main respawn_threshold "3600"
    config_get respawn_timeout main respawn_timeout "5"
    config_get respawn_retry main respawn_retry "5"

    if [ ! -f "$app_root/macflowd" ] && [ -f "/opt/macflow/macflowd" ]; then
        logger -t macflow "configured app_root not ready ($app_root), fallback to /opt/macflow"
        app_root="/opt/macflow"
    fi
    if [ ! -d "$data_dir" ]; then
        data_dir="$app_root/data"
    fi
}

# 自动探测当前所有 LAN/Bridge 接口 IP，生成 CORS Origins 列表
# 支持任意网段（192.168.x.x / 10.x.x.x / 172.16-31.x.x）
_build_cors_origins() {
    local port="$1"
    local origins="http://localhost:${port},http://localhost,http://127.0.0.1:${port},http://127.0.0.1"
    local ip
    # 枚举所有非 loopback IPv4 地址
    if command -v ip >/dev/null 2>&1; then
        for ip in $(ip -4 addr show scope global 2>/dev/null | awk '/inet / {split($2,a,"/"); print a[1]}'); do
            origins="${origins},http://${ip}:${port},http://${ip}"
        done
    fi
    printf '%s' "$origins"
}

start_service() {
    _load_cfg
    [ "$enabled" = "1" ] || return 0

    mkdir -p "$app_root" "$data_dir"

    local cors_origins
    cors_origins="$(_build_cors_origins "$listen_port")"

    procd_open_instance
    procd_set_param command "$app_root/macflowd"
    procd_set_param respawn "$respawn_threshold" "$respawn_timeout" "$respawn_retry"
    procd_append_param env MACFLOW_LISTEN_PORT="$listen_port"
    procd_append_param env MACFLOW_BIND="$bind_addr"
    procd_append_param env MACFLOW_DATA_DIR="$data_dir"
    procd_append_param env MACFLOW_WEB_DIR="$app_root/web"
    procd_append_param env MACFLOW_CLASH_API="$clash_api"
    procd_append_param env MACFLOW_CORS_ORIGINS="$cors_origins"
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile /var/run/macflow.pid
    procd_set_param file "$app_root/macflowd"
    procd_close_instance
}

stop_service() {
    return 0
}

reload_service() {
    restart
}

service_triggers() {
    procd_add_reload_trigger "macflow"
    # WAN ifup 由 hotplug.d/iface/99-macflow 处理（POST /api/apply）
    # 这里不再重复添加接口触发器以避免双重 restart+apply
}
